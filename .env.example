# ==========================================
# 网枢 NetHub 环境变量配置模板 (示例)
# 使用说明：复制本文件为 .env 并填写实际值
# ==========================================

# 内核通信密钥 (Clash API Secret)
# 必填：建议使用长随机字符串（如：openssl rand -base64 32）
CLASH_API_SECRET=

# 节点库加密密码 (Vault Password)
# 选填：若使用节点库加密功能，请在此设置全局解密密码
VAULT_PASSWORD=

# ------------------------------------------
# 管理面板设置
# ------------------------------------------

# 管理员账号 (访问 Web 界面时使用)
PANEL_ADMIN_USER=admin

# 管理员密码 (必填：建议设置强密码)
PANEL_ADMIN_PASSWORD=

# 会话安全密钥 (Session Secret)
# 必填：用于加密浏览器 Cookie，建议设置为随机字符串
PANEL_SESSION_SECRET=

# sing-box Docker 镜像（生产环境建议固定到明确版本或 digest）
SINGBOX_IMAGE=ghcr.io/sagernet/sing-box:latest

# HTTP 代理服务监听端口 (改掉默认的 2080 可以瞬间屏蔽 99% 的公网恶意扫描流量)
# 选填：默认值为 2080，建议修改为 1024-65535 之间的任意高位随机端口（例如：34567）
SINGBOX_HTTP_PORT=2080

# HTTP 代理端口身份认证 (防止他人扫端口白嫖/蹭网)
# 选填：不填表示免密码公开代理；填写后客户端连接代理时需输入账密
SINGBOX_HTTP_USER=
SINGBOX_HTTP_PASS=

# 订阅源后台刷新间隔（分钟）。需要同时设置 VAULT_PASSWORD；0 表示关闭。
PANEL_SUB_REFRESH_INTERVAL_MIN=0

# 可选：sing-box JSON 模板覆盖文件路径，用于自定义 DNS/路由/入站等字段。
SINGBOX_TEMPLATE_PATH=

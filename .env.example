# ==========================================
# 网枢 NetHub 环境变量模板
# 说明：复制为 .env 后填写真实值。
# ==========================================

# ------------------------------------------
# 内核通信与节点库
# ------------------------------------------

# Clash API 通信密钥：面板用于连接 sing-box 控制接口，必须设置为长随机字符串。
CLASH_API_SECRET=

# 节点库加密密码：启用 Vault 和订阅后台刷新时使用；不使用可留空。
VAULT_PASSWORD=

# ------------------------------------------
# 管理面板
# ------------------------------------------

# 管理员账号：访问 Web 面板时使用。
PANEL_ADMIN_USER=admin

# 管理员密码：建议使用强密码，生产环境不要使用默认弱密码。
PANEL_ADMIN_PASSWORD=

# 会话安全密钥：用于签名浏览器 Cookie，建议使用长随机字符串。
PANEL_SESSION_SECRET=

# 管理面板公网端口：Docker 部署时映射到容器内 8080。
PANEL_PORT=8080

# ------------------------------------------
# Docker 与 sing-box
# ------------------------------------------

# sing-box Docker 镜像：生产环境建议固定到明确版本或 digest，避免 latest 自动变化。
SINGBOX_IMAGE=ghcr.io/sagernet/sing-box:latest

# HTTP 代理公网端口：客户端连接服务器的端口；Docker 内部仍固定转发到 2080。
SINGBOX_HTTP_PORT=2080

# HTTP/HTTPS 代理认证账号：留空表示不启用代理认证，公网环境建议配合防火墙或账号密码使用。
SINGBOX_HTTP_USER=
SINGBOX_HTTP_PASS=

# ------------------------------------------
# HTTPS 代理入口
# ------------------------------------------

# 是否启用 HTTPS 正向代理：1 表示启用，0 表示关闭。
SINGBOX_HTTPS_PROXY_ENABLED=0

# HTTPS 代理公网端口：客户端使用 https://域名:端口 连接；Docker 内部固定转发到 2443。
SINGBOX_HTTPS_PROXY_PUBLIC_PORT=2443

# TLS 证书目录：Docker 会把该目录只读挂载到容器内 /certs。
SINGBOX_TLS_CERT_DIR=./certs

# TLS 证书文件路径：这是容器内路径，不是宿主机路径。
SINGBOX_TLS_CERT_PATH=/certs/fullchain.pem

# TLS 私钥文件路径：这是容器内路径，不是宿主机路径。
SINGBOX_TLS_KEY_PATH=/certs/privkey.pem

# TLS 服务域名：建议填写证书对应的域名，例如 proxy.example.com。
SINGBOX_TLS_SERVER_NAME=

# ------------------------------------------
# 自动维护与高级配置
# ------------------------------------------

# 订阅后台刷新间隔，单位分钟；需要同时设置 VAULT_PASSWORD，0 表示关闭。
PANEL_SUB_REFRESH_INTERVAL_MIN=0

# sing-box JSON 模板覆盖文件路径：高级用户可用于自定义 DNS、路由、入站等字段。
SINGBOX_TEMPLATE_PATH=
